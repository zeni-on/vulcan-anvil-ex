{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Bash(python *)",
      "Bash(mkdir *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(cd *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python vulcan.py check-trace 2>/dev/null || true",
            "statusMessage": "산출물 정합성 검증 중..."
          }
        ]
      }
    ]
  }
}
