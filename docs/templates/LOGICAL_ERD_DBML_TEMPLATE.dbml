// Logical ERD DBML
// 목적: 논리 엔티티, 주요 속성, 관계를 사람이 검토하기 쉬운 형태로 정의한다.
// 주의: 물리 DB 타입, 인덱스, DBMS별 옵션은 physical-erd.dbml에 확정한다.

Project logical_erd {
  database_type: 'Logical'
  Note: '''
  논리 ERD 원본입니다.
  - 엔티티명은 업무 논리명을 우선 사용합니다.
  - 주요 속성, 식별자, 관계, 선택/필수 여부를 표현합니다.
  - DB명세서의 DB-ID, TERM-ID와 연결되도록 주석을 남깁니다.
  '''
}

Table "ENTITY_001" as entity_001 {
  "id" varchar [pk, note: 'DB-001 / TERM-']
  "name" varchar [not null, note: 'TERM-']

  Note: '''
  DB-ID: DB-001
  논리명:
  관련 REQ/FUNC/PGM:
  '''
}

// Ref: entity_002.entity_001_id > entity_001.id
